generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTANT
  VIEWER
}

model User {
  id                  Int               @id @default(autoincrement())
  username            String            @unique
  email               String            @unique
  fullName            String
  passwordHash        String
  profilePicture      String?
  role                Role              @default(VIEWER)
  isVerified          Boolean           @default(false)
  isLocked            Boolean           @default(false)
  failedLoginAttempts Int               @default(0)
  lockUntil           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  otps                OTP[]
  sessions            Session[]
  auditLogs           AuditLog[]
  financialEntities   FinancialEntity[]
  contracts           Contract[]
  transactions        Transaction[]
}

model OTP {
  id        Int      @id @default(autoincrement())
  userId    Int
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id               String   @id @default(uuid())
  userId           Int
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  isValid          Boolean  @default(true)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum EntityType {
  REVENUE
  EXPENSE
  CUSTODY
}

model FinancialEntity {
  id             Int           @id @default(autoincrement())
  name           String
  type           EntityType
  initialBalance Float         @default(0.0)
  userId         Int           // Now mandatory
  clientGuid     String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  user           User          @relation(fields: [userId], references: [id])
  transactions   Transaction[]
  contracts      Contract[]
}

model Contract {
  id               Int             @id @default(autoincrement())
  financialEntityId Int
  tenantName       String
  startDate        DateTime
  endDate          DateTime
  monthlyRent      Float
  isActive         Boolean         @default(true)
  userId           Int             // Now mandatory
  clientGuid       String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id])
  entity           FinancialEntity @relation(fields: [financialEntityId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  IN
  OUT
}

model Transaction {
  id               Int             @id @default(autoincrement())
  amount           Float
  type             TransactionType
  entityId         Int
  notes            String?
  personName       String?
  isCashReturn     Boolean         @default(true)
  receiptImagePath String?
  userId           Int             // Now mandatory
  timestamp        DateTime        @default(now())
  clientGuid       String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id])
  entity           FinancialEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}


