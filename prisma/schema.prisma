generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTANT
  VIEWER
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  email          String   @unique
  fullName       String
  password       String
  profilePicture String?
  role           Role     @default(VIEWER)
  isVerified             Boolean  @default(false)
  verificationToken      String?  @unique
  verificationTokenExpiry DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

enum EntityType {
  REVENUE
  EXPENSE
  CUSTODY
}

model FinancialEntity {
  id             Int          @id @default(autoincrement())
  name           String
  type           EntityType
  initialBalance Float        @default(0.0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  transactions   Transaction[]
  contracts      Contract[]
}

model Contract {
  id               Int             @id @default(autoincrement())
  financialEntityId Int
  tenantName       String
  startDate        DateTime
  endDate          DateTime
  monthlyRent      Float
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  entity           FinancialEntity @relation(fields: [financialEntityId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  IN
  OUT
}

model Transaction {
  id               Int             @id @default(autoincrement())
  amount           Float
  type             TransactionType
  entityId         Int
  notes            String?
  personName       String?
  isCashReturn     Boolean         @default(true)
  receiptImagePath String?
  timestamp        DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  entity           FinancialEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}
